generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String     @id @default(cuid())
  email                  String     @unique
  firebaseUid            String?    @unique
  name                   String?
  username               String?    @unique
  avatarUrl              String?
  timezone               String     @default("America/Tegucigalpa")
  selectedProjectLocalId String?
  projects               Project[]
  habits                 Habit[]
  reminders              Reminder[]
  habitMeta              HabitMeta?
  rowCreatedAt           DateTime   @default(now())
  rowUpdatedAt           DateTime   @updatedAt
}

