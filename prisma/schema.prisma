generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
     url     = env("DATABASE_URL")
}

enum TaskStatus {
  TODO
  DOING
  DONE
  CANCELED
  ARCHIVED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EntityType {
  PLACE
  PERSON
  ORG
  OBJECT
  OTHER
}

enum TaskEventType {
  CREATED
  UPDATED
  MOVED
  STATUS_CHANGED
  COMPLETED
  CANCELED
  DELETED
  NOTE_ADDED
  ENTITY_LINKED
  ENTITY_UNLINKED
}

model User {
  id           String              @id @default(cuid())
  email        String              @unique
  name         String?
  username     String?             @unique
  avatarUrl    String?
  aiContext    String              @default("")
  timezone     String              @default("America/Tegucigalpa")
  projects     Project[]
  tasks        Task[]
  entities     Entity[]
  events       TaskEvent[]
  interactions EntityInteraction[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([email])
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String   @default("")
  isArchived  Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, isArchived])
}

model Task {
  id           String              @id @default(cuid())
  userId       String
  projectId    String?
  title        String
  description  String              @default("")
  status       TaskStatus          @default(TODO)
  priority     TaskPriority        @default(MEDIUM)
  dueAt        DateTime?
  startAt      DateTime?
  completedAt  DateTime?
  column       String?
  position     Int                 @default(0)
  aiTags       String              @default("")
  aiSummary    String              @default("")
  aiPlan       String              @default("")
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  entities     TaskEntity[]
  events       TaskEvent[]
  interactions EntityInteraction[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([userId, status])
  @@index([userId, dueAt])
  @@index([projectId])
}

model Entity {
  id           String              @id @default(cuid())
  userId       String
  type         EntityType          @default(OTHER)
  name         String
  normalized   String?
  meta         String              @default("")
  aiSummary    String              @default("")
  lastSeenAt   DateTime?
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks        TaskEntity[]
  interactions EntityInteraction[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([userId, type])
  @@index([userId, name])
  @@unique([userId, normalized])
}

model TaskEntity {
  taskId       String
  entityId     String
  relationNote String              @default("")
  confidence   Int                 @default(100)
  task         Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  entity       Entity              @relation(fields: [entityId], references: [id], onDelete: Cascade)
  createdAt    DateTime            @default(now())

  @@id([taskId, entityId])
  @@index([entityId])
  @@index([taskId])
}

model TaskEvent {
  id        String        @id @default(cuid())
  userId    String
  taskId    String
  type      TaskEventType
  payload   String        @default("")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([taskId, createdAt])
  @@index([userId, createdAt])
}

model EntityInteraction {
  id         String   @id @default(cuid())
  userId     String
  entityId   String
  note       String   @default("")
  taskId     String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity     Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  happenedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([entityId, happenedAt])
  @@index([userId, happenedAt])
}
