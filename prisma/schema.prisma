model Habit {
  id           String   @id @default(cuid())
  userId       String
  localId      String
  text         String   @default("")
  checked      Boolean  @default(false)
  weekly       Boolean  @default(false)
  position     Int      @default(0)
  createdAt    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rowCreatedAt DateTime @default(now())
  rowUpdatedAt DateTime @updatedAt

  @@unique([userId, localId])
  @@index([userId, position])
}

model HabitMeta {
  id                 String   @id @default(cuid())
  userId             String   @unique
  lastDailyResetYMD  String?
  lastWeeklyResetYMD String?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rowCreatedAt       DateTime @default(now())
  rowUpdatedAt       DateTime @updatedAt
}

model Reminder {
  id           String   @id @default(cuid())
  userId       String
  localId      String
  title        String   @default("")
  date         String
  time         String
  daily        Boolean  @default(false)
  position     Int      @default(0)
  flag         String?
  createdAt    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rowCreatedAt DateTime @default(now())
  rowUpdatedAt DateTime @updatedAt

  @@unique([userId, localId])
  @@index([userId, date])
  @@index([userId, position])
}