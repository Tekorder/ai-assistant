generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  firebaseUid String? @unique
  name      String?
  username  String? @unique
  avatarUrl String?
  timezone  String  @default("America/Tegucigalpa")

  selectedProjectLocalId String?

  projects  Project[]
  habits    Habit[]
  reminders Reminder[]
  habitMeta HabitMeta?

  rowCreatedAt DateTime @default(now())
  rowUpdatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// PROJECT
// project_id del JSON vive en localId
// collapsed y quickCollapsed viven aquí porque así viene el objeto
// ─────────────────────────────────────────────────────────────

model Project {
  id         String  @id @default(cuid())
  userId     String
  localId    String
  title      String
  isArchived Boolean @default(false)

  collapsed      Json @default("{}")
  quickCollapsed Json @default("{}")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks Block[]

  rowCreatedAt DateTime @default(now())
  rowUpdatedAt DateTime @updatedAt

  @@unique([userId, localId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// BLOCK
// localId = id del block en localStorage
// createdAt = fecha semántica del frontend (YYYY-MM-DD)
// rowCreatedAt / rowUpdatedAt = timestamps reales de BD
// ─────────────────────────────────────────────────────────────

model Block {
  id        String @id @default(cuid())
  projectId String
  localId   String

  text     String @default("")
  indent   Int    @default(0)
  position Int    @default(0)

  checked   Boolean?
  deadline  String?
  createdAt String?
  isHidden  Boolean  @default(false)
  archived  Boolean  @default(false)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  rowCreatedAt DateTime @default(now())
  rowUpdatedAt DateTime @updatedAt

  @@unique([projectId, localId])
  @@index([projectId, position])
  @@index([projectId])
  @@index([deadline])
  @@index([archived])
}

// ─────────────────────────────────────────────────────────────
// HABIT
// personal — no se comparte
// ─────────────────────────────────────────────────────────────

model Habit {
  id      String @id @default(cuid())
  userId  String
  localId String

  text      String  @default("")
  checked   Boolean @default(false)
  weekly    Boolean @default(false)
  position  Int     @default(0)
  createdAt String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  rowCreatedAt DateTime @default(now())
  rowUpdatedAt DateTime @updatedAt

  @@unique([userId, localId])
  @@index([userId, position])
}

// ─────────────────────────────────────────────────────────────
// HABIT META
// uno por usuario
// ─────────────────────────────────────────────────────────────

model HabitMeta {
  id     String @id @default(cuid())
  userId String @unique

  lastDailyResetYMD  String?
  lastWeeklyResetYMD String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  rowCreatedAt DateTime @default(now())
  rowUpdatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// REMINDER
// personal — no se comparte
// ─────────────────────────────────────────────────────────────

model Reminder {
  id      String @id @default(cuid())
  userId  String
  localId String

  title     String  @default("")
  date      String
  time      String
  daily     Boolean @default(false)
  position  Int     @default(0)
  createdAt String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  rowCreatedAt DateTime @default(now())
  rowUpdatedAt DateTime @updatedAt

  @@unique([userId, localId])
  @@index([userId, date])
  @@index([userId, position])
}
