generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String     @id @default(cuid())
  email                  String     @unique
  firebaseUid            String?    @unique
  name                   String?
  username               String?    @unique
  avatarUrl              String?
  timezone               String     @default("America/Tegucigalpa")
  selectedProjectLocalId String?
  onboarded              Boolean    @default(false)
  projects               Project[]
  habits                 Habit[]
  reminders              Reminder[]
  habitMeta              HabitMeta?
  rowCreatedAt           DateTime   @default(now())
  rowUpdatedAt           DateTime   @updatedAt
}

model Project {
  id             String   @id @default(cuid())
  userId         String
  localId        String
  title          String
  isArchived     Boolean  @default(false)
  collapsed      Json     @default("{}")
  quickCollapsed Json     @default("{}")
  visibleLists   Json     @default("{}")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks         Block[]
  rowCreatedAt   DateTime @default(now())
  rowUpdatedAt   DateTime @updatedAt

  @@unique([userId, localId])
  @@index([userId])
}

model Block {
  id            String   @id @default(cuid())
  projectId     String
  localId       String
  parentLocalId String?
  text          String   @default("")
  indent        Int      @default(0)
  order         Int      @default(0)
  checked       Boolean?
  deadline      String?
  createdAt     String?
  isHidden      Boolean  @default(false)
  archived      Boolean  @default(false)
  flag          String?
  priority      Boolean  @default(false)
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rowCreatedAt  DateTime @default(now())
  rowUpdatedAt  DateTime @updatedAt

  @@unique([projectId, localId])
  @@index([projectId, parentLocalId, order])
  @@index([projectId])
  @@index([deadline])
  @@index([archived])
}

model Habit {
  id           String   @id @default(cuid())
  userId       String
  localId      String
  text         String   @default("")
  checked      Boolean  @default(false)
  weekly       Boolean  @default(false)
  position     Int      @default(0)
  createdAt    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rowCreatedAt DateTime @default(now())
  rowUpdatedAt DateTime @updatedAt

  @@unique([userId, localId])
  @@index([userId, position])
}

model HabitMeta {
  id                 String   @id @default(cuid())
  userId             String   @unique
  lastDailyResetYMD  String?
  lastWeeklyResetYMD String?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rowCreatedAt       DateTime @default(now())
  rowUpdatedAt       DateTime @updatedAt
}

model Reminder {
  id           String   @id @default(cuid())
  userId       String
  localId      String
  title        String   @default("")
  date         String
  time         String
  daily        Boolean  @default(false)
  position     Int      @default(0)
  flag         String?
  createdAt    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rowCreatedAt DateTime @default(now())
  rowUpdatedAt DateTime @updatedAt

  @@unique([userId, localId])
  @@index([userId, date])
  @@index([userId, position])
}
